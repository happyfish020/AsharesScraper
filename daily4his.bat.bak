@echo off
setlocal

set "PYTHON_EXE=C:\Apps\Python\Python312\python.exe"
set "RUNNER_PY=D:\LHJ\PythonWS\MarketScraper\AsharesScraperV2\runner.py"
set "WORKDIR=D:\LHJ\PythonWS\MarketScraper\AsharesScraperV2"

rem Pass extra runner args after the bat, e.g.:
rem   daily.bat --start-date 2026-05-01 --end-date 2026-05-15
rem   daily.bat --asof latest --days 5
set "EXTRA_ARGS=%*"
if "%EXTRA_ARGS%"=="" set "EXTRA_ARGS=--asof latest --days 1"

rem Shared Tushare transport defaults
set "TUSHARE_PRO_TIMEOUT_SECONDS=45"
set "TUSHARE_PRO_HTTP_MAX_RETRIES=4"
set "TUSHARE_PRO_HTTP_BACKOFF_SECONDS=1.5"

rem Daily audit and auto-repair defaults
set "V8_DAILY_AUTO_REPAIR=1"
set "V8_DAILY_AUDIT_LOOKBACK_DAYS=6000"
set "V8_DAILY_REPAIR_LOOKBACK_DAYS=6000"
set "V8_DAILY_REPAIR_MAX_LOOKBACK_DAYS=6000"
set "ROTATION_AUTO_BACKFILL_MISSING=6000"
set "ROTATION_AUTO_REPAIR_DOWNSTREAM=6000"
set "V8_DAILY_INCLUDE_VALIDATIONS=6000"
set "V8_DAILY_INCLUDE_CROSSWALK_LATEST=6000"

cd /d "%WORKDIR%"

REM Daily split responsibilities:
REM   1) v8_daily_market_raw           -> stock/index daily raw refresh
REM   2) v8_daily_reference            -> sw industry, rotation sector, event daily
REM   3) v8_rotation_repair            -> rotation-specific audit + missing upstream/downstream repair
REM   4) v8_daily_audit                -> stock/index coverage audit + targeted index repair
REM   5) v8_daily_derived_foundation   -> fundamental daily/quality/capital flow/role map
REM   6) v8_daily_derived_mainline     -> mainline strength/radar/pulse/lifecycle + validations
REM   7) v8_daily_derived_alpha        -> unified alpha + validations + latest crosswalk

for %%T in (v8_daily_market_raw v8_daily_reference v8_rotation_repair v8_daily_audit v8_daily_derived_foundation v8_daily_derived_mainline v8_daily_derived_alpha) do (
    echo [DAILY] %%T %EXTRA_ARGS%
    "%PYTHON_EXE%" "%RUNNER_PY%" --flag tu --tasks %%T %EXTRA_ARGS%
    if errorlevel 1 goto :fail
)

echo [DAILY] done
exit /b 0

:fail
echo [DAILY] failed with exit code %ERRORLEVEL%
exit /b %ERRORLEVEL%
