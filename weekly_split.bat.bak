@echo off
setlocal

REM ============================================================
REM Weekly split pipeline. Refresh and audit are separated so a
REM failed audit can be rerun without downloading weekly data again.
REM Usage:
REM   weekly_split.bat --start-date 2010-01-01 --end-date 2010-12-31
REM ============================================================

set SCRIPT_DIR=%~dp0
set PYTHON_EXE=python
set RUNNER_PY=%SCRIPT_DIR%runner.py
set EXTRA_ARGS=%*

for %%T in (
    v8_weekly_refresh
    v8_weekly_audit
    v8_weekly_finalize
) do (
    echo [WEEKLY_SPLIT] %%T %EXTRA_ARGS%
    "%PYTHON_EXE%" "%RUNNER_PY%" --flag tu --tasks %%T %EXTRA_ARGS%
    if errorlevel 1 goto :fail
)

echo [WEEKLY_SPLIT] completed successfully.
exit /b 0

:fail
echo [WEEKLY_SPLIT] failed with exit code %ERRORLEVEL%
exit /b %ERRORLEVEL%
